# Base URL of the Django REST API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Google Identity Services client ID (for Google login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Microsoft Entra ID (Azure AD) application client ID (for Microsoft login)
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
NEXT_PUBLIC_MICROSOFT_TENANT_ID=common
